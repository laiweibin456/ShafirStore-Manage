<view class="settings-page">
  <view class="form-section">
    <view class="form-item">
      <text class="form-label">昵称</text>
      <input class="form-input" placeholder="请输入昵称" value="{{nickname}}" bindinput="onNicknameInput" maxlength="20" />
    </view>
    
    <view class="form-item">
      <text class="form-label">手机号</text>
      <text class="form-value">{{phone}}</text>
    </view>
    
    <view class="form-item">
      <text class="form-label">会员等级</text>
      <text class="form-value">{{levelName}}</text>
    </view>
    
    <view class="form-item">
      <text class="form-label">累计消费</text>
      <text class="form-value">¥{{totalConsume}}</text>
    </view>
    
    <view class="form-item">
      <text class="form-label">当前积分</text>
      <text class="form-value">{{points}}</text>
    </view>
  </view>
  
  <view class="form-section">
    <view class="section-title">修改密码</view>
    <view class="form-item">
      <text class="form-label">原密码</text>
      <input class="form-input" placeholder="请输入原密码" password="{{true}}" value="{{oldPassword}}" bindinput="onOldPasswordInput" maxlength="20" />
    </view>
    
    <view class="form-item">
      <text class="form-label">新密码</text>
      <input class="form-input" placeholder="请输入新密码" password="{{true}}" value="{{newPassword}}" bindinput="onNewPasswordInput" maxlength="20" />
    </view>
    
    <view class="form-item">
      <text class="form-label">确认密码</text>
      <input class="form-input" placeholder="请再次输入新密码" password="{{true}}" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" maxlength="20" />
    </view>
  </view>
  
  <view class="btn-section">
    <button class="btn-save" bindtap="saveUserInfo">保存修改</button>
  </view>
</view>
