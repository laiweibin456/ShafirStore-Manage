<view class="register-page">
  <view class="logo-section">
    <text class="app-name">莎菲尔菓子</text>
    <text class="app-desc">加入我们，享受更多会员权益</text>
  </view>

  <view class="form-section">
    <view class="input-group">
      <text class="label">手机号</text>
      <input class="input" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
    </view>

    <view class="input-group">
      <text class="label">密码</text>
      <input class="input" password type="text" placeholder="请设置密码" value="{{password}}" bindinput="onPasswordInput" />
    </view>

    <view class="input-group">
      <text class="label">确认密码</text>
      <input class="input" password type="text" placeholder="请再次输入密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
    </view>

    <view class="input-group">
      <text class="label">昵称（选填）</text>
      <input class="input" type="text" placeholder="请输入昵称" value="{{nickname}}" bindinput="onNicknameInput" />
    </view>

    <button class="btn-register" bindtap="onRegister">注册</button>

    <view class="login-link">
      <text>已有账号？</text>
      <text class="link" bindtap="goToLogin">立即登录</text>
    </view>
  </view>
</view>