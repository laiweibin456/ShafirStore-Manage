/* pages/member/index/index.wxss - 会员中心页面样式(极简) */

.member-page {
  min-height: 100vh;
  background-color: #F5F5F5;
}

/* ==================== 登录区域（未登录状态） ==================== */
.login-section {
  background-color: #FFFFFF;
  padding: 60rpx 40rpx;
  padding-top: calc(100rpx + env(safe-area-inset-top));
}

.login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background-color: #f5f5f5;
  margin-bottom: 30rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.login-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 50rpx;
}

.btn-login {
  width: 100%;
  height: 88rpx;
  background-color: #E6A23C;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-login::after {
  border: none;
}

/* ==================== 用户信息区域 ==================== */
.user-section {
  background-color: #FFFFFF;
  padding: 40rpx 24rpx 32rpx;
  padding-top: calc(40rpx + env(safe-area-inset-top));
}

.user-card {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: #E6A23C;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.avatar-text {
  font-size: 40rpx;
  color: #fff;
  font-weight: 600;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  display: block;
  font-size: 34rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.member-badge {
  display: inline-block;
  background-color: #FFF3E0;
  border: 1rpx solid #E6A23C;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #E6A23C;
}

.logout-btn {
  padding: 12rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 30rpx;
}

.logout-text {
  font-size: 24rpx;
  color: #666;
}

/* ==================== 会员进度卡片 ==================== */
.member-progress-card {
  background-color: #FFF8F0;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-top: 30rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.progress-hint {
  font-size: 22rpx;
  color: #E6A23C;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-level {
  display: flex;
  align-items: center;
}

.level-name {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-right: 16rpx;
}

.level-discount {
  font-size: 24rpx;
  color: #E6A23C;
  background-color: #FFE5C8;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.progress-stats {
  text-align: right;
}

.stats-label {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.stats-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.progress-bar {
  margin-top: 10rpx;
}

.progress-bar-bg {
  height: 16rpx;
  background-color: #FFE5C8;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #E6A23C, #FF9800);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-tips {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
}

.tips-current,
.tips-next {
  font-size: 22rpx;
  color: #999;
}

.max-level-hint {
  font-size: 24rpx;
  color: #E6A23C;
  text-align: center;
}

/* ==================== 用户信息区域（已登录） ==================== */
.user-section {
  background-color: #FFFFFF;
  padding: 40rpx 24rpx 32rpx;
  padding-top: calc(40rpx + env(safe-area-inset-top));
}

.user-card {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.user-avatar text {
  font-size: 36rpx;
  color: #999999;
  font-weight: 500;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  display: block;
  font-size: 34rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.member-badge {
  display: inline-block;
  border: 1rpx solid #D0D0D0;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #999999;
}

/* 右箭头 */
.arrow-right {
  padding: 16rpx;
  flex-shrink: 0;
}

.icon-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid #C0C0C0;
  border-right: 3rpx solid #C0C0C0;
  transform: rotate(45deg);
}

/* ==================== 数据统计 ==================== */
.stats-row {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  padding: 32rpx 24rpx;
  margin-top: 1rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  color: #333333;
  font-weight: bold;
  line-height: 1.2;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #E8E8E8;
}

/* ==================== 会员码 ==================== */
.member-code-card {
  background-color: #FFFFFF;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
}

.code-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.code-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
}

.code-hint {
  font-size: 22rpx;
  color: #999999;
}

.code-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  border: 1rpx solid #F0F0F0;
  border-radius: 12rpx;
}

.barcode {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-bottom: 16rpx;
}

.code-number {
  font-size: 24rpx;
  color: #666666;
  letter-spacing: 4rpx;
}

/* ==================== 功能菜单 ==================== */
.menu-section {
  background-color: #FFFFFF;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
  transition: background-color 0.15s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #FAFAFA;
}

/* 菜单图标容器 */
.menu-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid #D0D0D0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

/* CSS纯线条图标 - 订单(矩形+横线) */
.icon-order {
  width: 20rpx;
  height: 22rpx;
  border: 2rpx solid #333333;
  border-radius: 2rpx;
  position: relative;
}

.icon-order::before {
  content: '';
  position: absolute;
  top: 6rpx;
  left: 3rpx;
  right: 3rpx;
  height: 2rpx;
  background-color: #333333;
}

.icon-order::after {
  content: '';
  position: absolute;
  top: 12rpx;
  left: 3rpx;
  right: 3rpx;
  height: 2rpx;
  background-color: #333333;
}

/* CSS纯线条图标 - 积分(菱形) */
.icon-point {
  width: 14rpx;
  height: 14rpx;
  border: 2rpx solid #333333;
  transform: rotate(45deg);
}

/* CSS纯线条图标 - 门店(房子) */
.icon-store {
  width: 18rpx;
  height: 14rpx;
  border: 2rpx solid #333333;
  border-top: none;
  position: relative;
}

.icon-store::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: -4rpx;
  width: 0;
  height: 0;
  border-left: 13rpx solid transparent;
  border-right: 13rpx solid transparent;
  border-bottom: 10rpx solid #333333;
}

/* CSS纯线条图标 - 电话(圆弧+竖线) */
.icon-phone {
  width: 8rpx;
  height: 16rpx;
  border: 2rpx solid #333333;
  border-radius: 4rpx 4rpx 0 0;
  border-bottom: none;
  position: relative;
}

.icon-phone::after {
  content: '';
  position: absolute;
  bottom: -6rpx;
  left: -2rpx;
  width: 8rpx;
  height: 4rpx;
  border: 2rpx solid #333333;
  border-top: none;
  border-radius: 0 0 4rpx 4rpx;
}

/* CSS纯线条图标 - 设置(齿轮简化) */
.icon-setting {
  width: 18rpx;
  height: 18rpx;
  border: 2rpx solid #333333;
  border-radius: 50%;
  position: relative;
}

.icon-setting::before {
  content: '';
  position: absolute;
  top: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 4rpx;
  height: 6rpx;
  background-color: #333333;
}

.icon-setting::after {
  content: '';
  position: absolute;
  bottom: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 4rpx;
  height: 6rpx;
  background-color: #333333;
}

.menu-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  flex-shrink: 0;
}

.menu-desc {
  flex: 1;
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-right: 12rpx;
}

/* 小箭头 */
.icon-arrow-small {
  width: 12rpx;
  height: 12rpx;
  border-top: 2rpx solid #C0C0C0;
  border-right: 2rpx solid #C0C0C0;
  transform: rotate(45deg);
  flex-shrink: 0;
}

/* ==================== 底部安全区域 ==================== */
.safe-area-bottom {
  height: 40rpx;
}
