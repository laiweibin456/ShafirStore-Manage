<view class="member-page">
  <!-- 未登录状态 -->
  <view class="login-section" wx:if="{{!hasUserInfo}}">
    <view class="login-card">
      <text class="login-title">莎菲尔菓子</text>
      <text class="login-desc">登录后享受更多会员权益</text>
      <button class="btn-login" bindtap="goToLogin">登录/注册</button>
    </view>
  </view>

  <!-- 已登录状态 -->
  <view class="user-section" wx:if="{{hasUserInfo}}">
    <view class="user-card">
      <view class="user-avatar">
        <text class="avatar-text">{{userAvatar}}</text>
      </view>
      <view class="user-info">
        <text class="user-name">{{userInfo.nickname || '用户'}}</text>
        <view class="member-badge">
          <text class="badge-text">{{userInfo.levelName || '普通用户'}}</text>
        </view>
      </view>
      <view class="logout-btn" bindtap="onLogout">
        <text class="logout-text">退出</text>
      </view>
    </view>

    <!-- 会员进度 -->
    <view class="member-progress-card">
      <view class="progress-header">
        <text class="progress-title">会员等级</text>
        <text class="progress-hint">消费达标自动升级</text>
      </view>
      <view class="progress-info">
        <view class="progress-level">
          <text class="level-name">{{userInfo.levelName || '普通用户'}}</text>
          <text class="level-discount" wx:if="{{showDiscount}}">
            {{discountText}}折
          </text>
        </view>
        <view class="progress-stats">
          <text class="stats-label">累计消费</text>
          <text class="stats-value">¥{{userInfo.totalConsume || 0}}</text>
        </view>
      </view>
      <view class="progress-bar" wx:if="{{userInfo.nextLevelThreshold}}">
        <view class="progress-bar-bg">
          <view class="progress-bar-fill" style="width: {{progressPercent}}%"></view>
        </view>
        <view class="progress-tips">
          <text class="tips-current">当前 {{userInfo.totalConsume || 0}}</text>
          <text class="tips-next">升级还需 ¥{{nextLevelAmount}}</text>
        </view>
      </view>
      <view class="progress-bar" wx:if="{{isMaxLevel}}">
        <text class="max-level-hint">您已是最高等级会员</text>
      </view>
    </view>

    <!-- 积分信息 -->
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-value">{{userInfo.points || 0}}</text>
        <text class="stat-label">积分</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{discountText}}</text>
        <text class="stat-label">折扣率</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goToOrders">
      <view class="menu-icon">
        <view class="icon-order"></view>
      </view>
      <text class="menu-text">我的订单</text>
      <text class="menu-desc">查看全部订单</text>
      <view class="icon-arrow-small"></view>
    </view>

    <view class="menu-item" bindtap="goToPoints">
      <view class="menu-icon">
        <view class="icon-point"></view>
      </view>
      <text class="menu-text">积分明细</text>
      <text class="menu-desc">{{userInfo.points || 0}}积分</text>
      <view class="icon-arrow-small"></view>
    </view>

    <view class="menu-item" bindtap="goToStoreSelect">
      <view class="menu-icon">
        <view class="icon-store"></view>
      </view>
      <text class="menu-text">切换门店</text>
      <text class="menu-desc">{{currentStoreName || '请选择门店'}}</text>
      <view class="icon-arrow-small"></view>
    </view>

    <view class="menu-item" bindtap="callService">
      <view class="menu-icon">
        <view class="icon-phone"></view>
      </view>
      <text class="menu-text">联系客服</text>
      <text class="menu-desc">在线咨询</text>
      <view class="icon-arrow-small"></view>
    </view>

    <view class="menu-item" bindtap="goToSettings">
      <view class="menu-icon">
        <view class="icon-setting"></view>
      </view>
      <text class="menu-text">设置</text>
      <text class="menu-desc">修改个人信息</text>
      <view class="icon-arrow-small"></view>
    </view>
  </view>

  <!-- 底部安全区域 -->
  <view class="safe-area-bottom"></view>
</view>