<!--pages/member/index/index.wxml-->
<view class="member-page">
  <!-- 会员信息 -->
  <view class="member-info" wx:if="{{hasUserInfo}}">
    <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
    <view class="info-text">
      <text class="nickname">{{userInfo.nickName}}</text>
      <text class="level">{{memberInfo.levelName}}</text>
    </view>
  </view>
  <view class="member-info" wx:else>
    <button class="login-btn" bindtap="getUserProfile">微信一键登录</button>
  </view>

  <!-- 会员码 -->
  <view class="member-code-card" wx:if="{{hasUserInfo}}">
    <view class="code-header">
      <text class="member-name">{{memberInfo.name}}</text>
      <text class="member-phone">{{memberInfo.phone}}</text>
    </view>
    <view class="qrcode-wrapper">
      <image class="qrcode" src="{{memberCodeUrl}}" mode="aspectFit" />
    </view>
    <text class="code-hint">出示给店员扫描</text>
  </view>

  <!-- 会员数据 -->
  <view class="member-stats" wx:if="{{hasUserInfo}}">
    <view class="stat-item">
      <text class="stat-value">{{memberInfo.points}}</text>
      <text class="stat-label">积分</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{memberInfo.totalConsume}}</text>
      <text class="stat-label">累计消费</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goToPoints">
      <text class="menu-icon">💰</text>
      <text class="menu-text">积分明细</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToOrders">
      <text class="menu-icon">📋</text>
      <text class="menu-text">我的订单</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToUser">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">></text>
    </view>
  </view>
</view>
