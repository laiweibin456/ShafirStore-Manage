/* pages/member/points/points.wxss - 积分明细页面样式 */

.points-page {
  min-height: 100vh;
  background-color: #F5F5F5;
}

/* 积分概览 */
.points-overview {
  background: linear-gradient(135deg, #E6A23C 0%, #FF9800 100%);
  padding: 80rpx 40rpx;
  text-align: center;
}

.points-value {
  display: block;
  font-size: 72rpx;
  font-weight: bold;
  color: #ffffff;
}

.points-label {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 16rpx;
}

/* 积分记录 */
.record-list {
  background-color: #ffffff;
  margin: 20rpx;
  border-radius: 12rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-info {
  flex: 1;
}

.record-type {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
}

.record-remark {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-top: 8rpx;
}

.record-time {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.record-points {
  font-size: 32rpx;
  font-weight: bold;
}

.record-points.add {
  color: #52C41A;
}

.record-points.minus {
  color: #FF4D4F;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.empty text {
  font-size: 28rpx;
  color: #999999;
}
