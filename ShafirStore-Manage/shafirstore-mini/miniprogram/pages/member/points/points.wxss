/* pages/member/points/points.wxss - 积分明细页面样式 */

.points-page {
  min-height: 100vh;
  background-color: #F5F5F5;
}

/* 积分概览 */
.points-overview {
  background: linear-gradient(135deg, #E6A23C 0%, #FF9800 100%);
  padding: 60rpx 40rpx;
  text-align: center;
}

.points-value {
  display: block;
  font-size: 72rpx;
  font-weight: bold;
  color: #ffffff;
}

.points-label {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 16rpx;
}

.points-tip {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 16rpx;
}

/* Tab切换 */
.tab-container {
  display: flex;
  background-color: #ffffff;
  border-bottom: 1rpx solid #EEEEEE;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #E6A23C;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #E6A23C;
  border-radius: 2rpx;
}

/* 积分兑换商品列表 */
.exchange-section {
  padding: 20rpx;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.product-item {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.product-item.disabled {
  opacity: 0.6;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background-color: #F5F5F5;
  flex-shrink: 0;
}

.product-image image {
  width: 100%;
  height: 100%;
}

.image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #CCCCCC;
  font-size: 24rpx;
}

.product-info {
  flex: 1;
  margin-left: 20rpx;
  min-width: 0;
}

.product-name {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  display: block;
  font-size: 32rpx;
  color: #FF4D4F;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.product-meta {
  display: flex;
  gap: 20rpx;
}

.product-points {
  font-size: 24rpx;
  color: #E6A23C;
}

.product-stock {
  font-size: 24rpx;
  color: #999999;
}

.exchange-btn {
  padding: 16rpx 32rpx;
  background-color: #E6A23C;
  border-radius: 30rpx;
  flex-shrink: 0;
}

.exchange-btn text {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
}

.exchange-btn.disabled {
  background-color: #CCCCCC;
}

/* 积分记录列表 */
.records-section {
  padding: 20rpx;
}

.record-list {
  background-color: #ffffff;
  border-radius: 12rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-info {
  flex: 1;
}

.record-type {
  display: block;
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
}

.record-remark {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-top: 8rpx;
}

.record-time {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.record-points {
  font-size: 32rpx;
  font-weight: bold;
}

.record-points.add {
  color: #52C41A;
}

.record-points.minus {
  color: #FF4D4F;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 40vh;
}

.empty text {
  font-size: 28rpx;
  color: #999999;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  padding: 32rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.modal-body {
  padding: 32rpx;
}

.modal-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-row:last-child {
  margin-bottom: 0;
}

.modal-label {
  font-size: 28rpx;
  color: #666666;
}

.modal-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.modal-value.highlight {
  color: #E6A23C;
  font-weight: bold;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #EEEEEE;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
}

.modal-btn.cancel {
  color: #666666;
  border-right: 1rpx solid #EEEEEE;
}

.modal-btn.confirm {
  color: #E6A23C;
  font-weight: bold;
}
