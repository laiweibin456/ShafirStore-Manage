.cart-page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 120rpx;
}

.cart-list {
  padding: 20rpx;
}

.cart-item {
  display: flex;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  align-items: center;
}

.item-checkbox {
  margin-right: 16rpx;
  flex-shrink: 0;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #D0D0D0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.checkbox.checked {
  background-color: #E6A23C;
  border-color: #E6A23C;
}

.checkbox text {
  font-size: 24rpx;
  color: #FFFFFF;
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: #F5F5F5;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.item-name {
  font-size: 28rpx;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-price {
  font-size: 28rpx;
  color: #E6A23C;
  font-weight: bold;
  margin-top: 16rpx;
}

.item-price.points-price {
  color: #52C41A;
}

.price-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
}

.points-exchange-tag {
  display: inline-block;
  background-color: #FFF7E6;
  border: 1rpx solid #E6A23C;
  border-radius: 4rpx;
  padding: 4rpx 12rpx;
  margin-top: 8rpx;
}

.points-exchange-tag text {
  font-size: 22rpx;
  color: #E6A23C;
}

.points-info {
  font-size: 22rpx;
  color: #E6A23C;
  margin-left: 8rpx;
}

.original-price {
  font-size: 22rpx;
  color: #999999;
  text-decoration: line-through;
  margin-left: 8rpx;
}

.total-points {
  font-size: 24rpx;
  color: #E6A23C;
  margin-left: 8rpx;
}

.item-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.quantity-control {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 48rpx;
  height: 48rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #333333;
}

.qty-btn:active {
  background-color: #E8E8E8;
}

.qty-num {
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333333;
  min-width: 48rpx;
  text-align: center;
}

.delete-btn {
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
}

.delete-btn:active {
  color: #FF4D4F;
}

.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.empty-icon {
  width: 80rpx;
  height: 80rpx;
  border: 4rpx solid #D0D0D0;
  border-radius: 50%;
  margin-bottom: 24rpx;
  position: relative;
}

.empty-icon::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 36rpx;
  height: 4rpx;
  background-color: #D0D0D0;
}

.empty-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 4rpx;
  height: 36rpx;
  background-color: #D0D0D0;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 30rpx;
}

.go-shopping {
  padding: 20rpx 60rpx;
  background-color: #E6A23C;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #ffffff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.select-all {
  display: flex;
  align-items: center;
}

.select-all-text {
  margin-left: 10rpx;
  font-size: 28rpx;
  color: #333333;
}

.total-info {
  flex: 1;
  text-align: right;
  margin-right: 20rpx;
}

.total-label {
  font-size: 28rpx;
  color: #333333;
}

.total-price {
  font-size: 36rpx;
  color: #E6A23C;
  font-weight: bold;
}

.checkout-btn {
  padding: 20rpx 40rpx;
  background-color: #E6A23C;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.checkout-btn.disabled {
  background-color: #D0D0D0;
}

.checkout-btn:active {
  opacity: 0.85;
}
