<view class="create-order-page">
  <view class="store-info-bar" wx:if="{{hasStore}}" bindtap="goToStoreSelect">
    <text class="store-info-text">📍 {{currentStoreName}}</text>
    <text class="store-info-switch">切换 ></text>
  </view>
  <view class="no-store-bar" wx:if="{{!hasStore}}" bindtap="goToStoreSelect">
    <text class="no-store-text">请先选择门店</text>
    <text class="no-store-btn">选择门店 ></text>
  </view>

  <view class="section" wx:if="{{hasStore}}">
    <view class="section-title">预定商品</view>
    <view class="order-item" wx:for="{{orderItems}}" wx:key="id">
      <image class="item-image" src="{{item.imageUrl || '/images/placeholder.jpg'}}" mode="aspectFill" />
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <view wx:if="{{item.isPointsExchange}}" class="points-exchange-tag">
          <text>积分兑换</text>
        </view>
        <view class="item-bottom">
          <text class="item-price {{item.isPointsExchange ? 'points-price' : ''}}">¥{{item.price}}</text>
          <text wx:if="{{item.isPointsExchange}}" class="points-cost">({{item.requiredPoints}}积分)</text>
          <text class="item-qty">x{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">取货时间</view>
    <view class="pickup-time-row">
      <view class="picker-wrap">
        <text class="picker-label">日期</text>
        <picker mode="selector" range="{{dateRange}}" range-key="label" value="{{dateIndex}}" bindchange="onDateChange">
          <view class="picker-value">
            {{dateRange[dateIndex].label}} {{dateRange[dateIndex].display}}
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
      <view class="picker-wrap">
        <text class="picker-label">时间</text>
        <picker mode="multiSelector" range="{{timeRange}}" value="{{timeIndex}}" bindchange="onTimeChange">
          <view class="picker-value">
            {{timeRange[0][timeIndex[0]]}}:{{timeRange[1][timeIndex[1]]}}
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
    </view>
    <view class="pickup-time-display" wx:if="{{hasPickupTime}}">
      <text class="pickup-time-text">预计取货：{{pickupTimeDisplay}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">备注</view>
    <textarea class="remark-input" placeholder="请输入备注信息（选填）" value="{{remark}}" bindinput="onRemarkInput" maxlength="200" />
  </view>

  <view class="section price-section">
    <view class="price-row">
      <text class="price-label">商品金额</text>
      <text class="price-value">¥{{totalAmount}}</text>
    </view>
    <view class="price-row" wx:if="{{discountAmount > 0}}">
      <text class="price-label">会员折扣({{discount * 10}}折)</text>
      <text class="price-value discount">-¥{{discountAmount}}</text>
    </view>
    <view class="price-row" wx:if="{{totalPoints > 0}}">
      <text class="price-label">积分消耗</text>
      <text class="price-value points">-{{totalPoints}}积分</text>
    </view>
    <view class="price-row total">
      <text class="price-label">实付金额</text>
      <text class="price-value total-price">¥{{payAmount}}</text>
    </view>
  </view>

  <view class="submit-bar">
    <view class="submit-info">
      <text class="submit-label">合计：</text>
      <text class="submit-price">¥{{payAmount}}</text>
    </view>
    <view class="submit-btn {{submitting ? 'disabled' : ''}}" bindtap="submitOrder">
      {{submitting ? '提交中...' : '提交预约'}}
    </view>
  </view>
</view>
