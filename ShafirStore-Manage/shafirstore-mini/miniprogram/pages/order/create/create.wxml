<view class="order-create-page">
  <!-- 商品清单 -->
  <view class="section">
    <view class="section-title">商品清单</view>
    <view class="goods-list">
      <view class="goods-item" wx:for="{{orderItems}}" wx:key="id">
        <image class="goods-image" src="{{item.imageUrl}}" mode="aspectFill" />
        <view class="goods-info">
          <text class="goods-name">{{item.name}}</text>
          <text class="goods-price">¥{{item.price}}</text>
        </view>
        <text class="goods-qty">x{{item.quantity}}</text>
      </view>
    </view>
  </view>

  <!-- 预约取货时间 -->
  <view class="section">
    <view class="section-title">预约取货时间</view>
    <picker mode="multiSelector" bindchange="onPickupTimeChange" value="{{pickupTimeIndex}}" range="{{pickupTimeRange}}">
      <view class="pickup-time-display">
        <text class="{{hasPickupTime ? '' : 'placeholder'}}">
          {{hasPickupTime ? pickupTimeDisplay : '请选择取货时间'}}
        </text>
        <view class="arrow-down"></view>
      </view>
    </picker>
  </view>

  <!-- 订单备注 -->
  <view class="section">
    <view class="section-title">订单备注</view>
    <input class="remark-input" placeholder="输入特殊需求（如：需要蜡烛）" bindinput="onRemarkInput" value="{{remark}}" />
  </view>

  <!-- 价格明细 -->
  <view class="price-detail">
    <view class="price-row">
      <text class="price-label">商品金额</text>
      <text class="price-value">¥{{totalAmount}}</text>
    </view>
    <view class="price-row" wx:if="{{discountAmount > 0}}">
      <text class="price-label">会员折扣</text>
      <text class="price-value discount">-¥{{discountAmount}}</text>
    </view>
    <view class="price-row total">
      <text class="price-label">合计</text>
      <text class="price-value">¥{{payAmount}}</text>
    </view>
    <view class="price-tip" wx:if="{{discountAmount > 0}}">
      <text>已享受 {{discount}} 折扣优惠</text>
    </view>
  </view>

  <!-- 提示信息 -->
  <view class="tips-section">
    <view class="tips-item">
      <text class="tips-icon">📝</text>
      <text class="tips-text">到店后出示订单号取货</text>
    </view>
    <view class="tips-item">
      <text class="tips-icon">⏰</text>
      <text class="tips-text">请在预约时间到店取货</text>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-bar">
    <view class="submit-btn" bindtap="submitOrder">提交预约</view>
  </view>
</view>