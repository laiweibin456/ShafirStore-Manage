/* pages/order/create/create.wxss - 创建订单页面样式 */

.order-create-page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 120rpx;
}

/* 区块 */
.section {
  background-color: #ffffff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

/* 商品列表 */
.goods-list {
  margin-top: 20rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.goods-info {
  flex: 1;
}

.goods-name {
  display: block;
  font-size: 28rpx;
  color: #333333;
}

.goods-price {
  display: block;
  font-size: 28rpx;
  color: #E6A23C;
  margin-top: 8rpx;
}

.goods-qty {
  font-size: 28rpx;
  color: #999999;
}

/* 支付方式 */
.pay-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.pay-item:last-child {
  border-bottom: none;
}

.pay-item text {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #333333;
}

/* 备注 */
.remark-input {
  width: 100%;
  padding: 20rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* 价格明细 */
.price-detail {
  background-color: #ffffff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 12rpx;
}

.price-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
}

.price-label {
  font-size: 28rpx;
  color: #666666;
}

.price-value {
  font-size: 28rpx;
  color: #333333;
}

.price-row.total {
  border-top: 1rpx solid #F5F5F5;
  margin-top: 10rpx;
  padding-top: 20rpx;
}

.price-row.total .price-label,
.price-row.total .price-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #E6A23C;
}

/* 提交按钮 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: #ffffff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.submit-btn {
  width: 100%;
  padding: 24rpx;
  background-color: #E6A23C;
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
}
