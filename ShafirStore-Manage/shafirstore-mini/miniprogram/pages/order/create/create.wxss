.create-order-page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 120rpx;
}

.section {
  background-color: #ffffff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

.order-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.order-item:last-child {
  border-bottom: none;
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: #F5F5F5;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-name {
  font-size: 28rpx;
  color: #333333;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-price {
  font-size: 28rpx;
  color: #E6A23C;
  font-weight: bold;
}

.item-qty {
  font-size: 26rpx;
  color: #999999;
}

.pickup-time-row {
  display: flex;
  justify-content: space-between;
}

.picker-wrap {
  flex: 1;
  margin-right: 20rpx;
}

.picker-wrap:last-child {
  margin-right: 0;
}

.picker-label {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 12rpx;
  display: block;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999999;
}

.pickup-time-display {
  margin-top: 20rpx;
  padding: 16rpx 24rpx;
  background-color: #FFF8E1;
  border-radius: 8rpx;
}

.pickup-time-text {
  font-size: 26rpx;
  color: #E6A23C;
}

.remark-input {
  width: 100%;
  height: 160rpx;
  padding: 20rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.price-section {
  margin-top: 20rpx;
}

.price-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.price-row.total {
  border-top: 1rpx solid #EEEEEE;
  margin-top: 12rpx;
  padding-top: 20rpx;
}

.price-label {
  font-size: 28rpx;
  color: #666666;
}

.price-value {
  font-size: 28rpx;
  color: #333333;
}

.price-value.discount {
  color: #67C23A;
}

.total-price {
  font-size: 36rpx;
  color: #E6A23C;
  font-weight: bold;
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #ffffff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.submit-info {
  flex: 1;
}

.submit-label {
  font-size: 28rpx;
  color: #333333;
}

.submit-price {
  font-size: 36rpx;
  color: #E6A23C;
  font-weight: bold;
}

.submit-btn {
  padding: 20rpx 60rpx;
  background-color: #E6A23C;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.submit-btn.disabled {
  background-color: #D0D0D0;
}

.submit-btn:active {
  opacity: 0.85;
}
