<!--pages/order/list/list.wxml - 订单列表页面-->
<view class="order-page">
  <!-- 顶部Tab切换 -->
  <view class="tab-bar">
    <view
      class="tab-item {{currentTab === index ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="index"
      bindtap="switchTab"
      data-index="{{index}}"
    >
      <text class="tab-text">{{item}}</text>
      <view class="tab-dot" wx:if="{{currentTab === index}}"></view>
    </view>
  </view>

  <!-- 订单列表 -->
  <scroll-view class="order-scroll" scroll-y>
    <view class="order-list">
      <view
        class="order-card"
        wx:for="{{orders}}"
        wx:key="id"
        bindtap="goToDetail"
        data-id="{{item.id}}"
      >
        <!-- 订单头部：店铺名 + 状态 -->
        <view class="order-header">
          <view class="shop-info">
            <view class="icon-shop"></view>
            <text class="shop-name">莎菲尔菓子</text>
          </view>
          <text class="order-status status-{{item.status}}">{{item.statusText}}</text>
        </view>

        <!-- 商品列表 -->
        <view class="order-goods">
          <view class="goods-item" wx:for="{{item.items}}" wx:for-item="goods" wx:key="id">
            <view class="goods-image-wrap">
              <image class="goods-image" src="{{goods.imageUrl || '/images/placeholder.jpg'}}" mode="aspectFill"></image>
            </view>
            <view class="goods-info">
              <text class="goods-name">{{goods.name}}</text>
              <text class="goods-spec" wx:if="{{goods.specName}}">{{goods.specName}}</text>
            </view>
            <view class="goods-right">
              <text class="goods-price">¥{{goods.price}}</text>
              <text class="goods-qty">x{{goods.quantity}}</text>
            </view>
          </view>
        </view>

        <!-- 订单底部：总价 + 操作按钮 -->
        <view class="order-footer">
          <view class="order-total">
            <text class="total-label">共{{item.totalCount}}件 实付</text>
            <text class="total-price">¥{{item.payAmount}}</text>
          </view>
          <view class="order-actions">
            <view
              class="action-btn secondary"
              wx:if="{{item.status === 1}}"
              catchtap="cancelOrder"
              data-id="{{item.id}}"
            >
              <text>取消订单</text>
            </view>
            <view
              class="action-btn primary"
              wx:if="{{item.status === 1}}"
              catchtap="confirmPickup"
              data-id="{{item.id}}"
            >
              <text>确认取货</text>
            </view>
            <view
              class="action-btn primary"
              wx:if="{{item.status === 2}}"
              catchtap="reorder"
              data-id="{{item.id}}"
            >
              <text>再来一单</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{orders.length === 0 && !loading}}">
      <view class="empty-icon"></view>
      <text class="empty-text">暂无相关订单</text>
    </view>
  </scroll-view>
</view>
