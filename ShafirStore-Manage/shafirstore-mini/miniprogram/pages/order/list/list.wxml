<view class="order-list-page">
  <view class="tab-bar">
    <view class="tab-item {{currentTab === index ? 'active' : ''}}"
          wx:for="{{tabs}}" wx:key="index"
          bindtap="switchTab" data-index="{{index}}">
      {{item}}
    </view>
  </view>

  <view class="login-tip" wx:if="{{!isLoggedIn}}">
    <text class="tip-text">请先登录查看订单</text>
    <view class="login-btn" bindtap="goToLogin">去登录</view>
  </view>

  <view class="order-list" wx:if="{{isLoggedIn}}">
    <view class="order-card" wx:for="{{orders}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="order-header">
        <text class="order-no">订单号：{{item.orderNo || item.id}}</text>
        <text class="order-status status-{{item.status}}">{{item.statusText}}</text>
      </view>

      <view class="order-products">
        <view class="product-item" wx:for="{{item.items}}" wx:for-item="product" wx:key="id">
          <image class="product-image" src="{{product.imageUrl || product.productImage || '/images/placeholder.jpg'}}" mode="aspectFill" />
          <view class="product-info">
            <text class="product-name">{{product.productName || product.name}}</text>
            <view class="product-bottom">
              <text class="product-price">¥{{product.price || product.productPrice}}</text>
              <text class="product-qty">x{{product.quantity}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="order-footer">
        <view class="order-time" wx:if="{{item.pickupTime}}">
          <text class="time-label">取货时间：</text>
          <text class="time-value">{{item.pickupTime}}</text>
        </view>
        <view class="order-amount">
          <text class="amount-label">合计：</text>
          <text class="amount-value">¥{{item.payAmount || item.totalAmount}}</text>
        </view>
      </view>

      <view class="order-actions" catchtap="">
        <view class="btn-action btn-cancel" wx:if="{{item.status === 1}}" catchtap="cancelOrder" data-id="{{item.id}}">取消预约</view>
        <view class="btn-action btn-confirm" wx:if="{{item.status === 1}}" catchtap="confirmPickup" data-id="{{item.id}}">确认取货</view>
        <view class="btn-action btn-reorder" wx:if="{{item.status === 2 || item.status === 3}}" catchtap="reorder">再次预定</view>
      </view>
    </view>

    <view class="empty-tip" wx:if="{{!loading && orders.length === 0}}">
      <text class="empty-text">暂无订单</text>
      <view class="go-shopping" bindtap="reorder">去逛逛</view>
    </view>

    <view class="loading-tip" wx:if="{{loading}}">加载中...</view>
  </view>
</view>
