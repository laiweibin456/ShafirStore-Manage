.order-list-page {
  min-height: 100vh;
  background-color: #F5F5F5;
}

.tab-bar {
  display: flex;
  background-color: #ffffff;
  padding: 0 10rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #E6A23C;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #E6A23C;
  border-radius: 2rpx;
}

.login-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.tip-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 30rpx;
}

.login-btn {
  padding: 20rpx 60rpx;
  background-color: #E6A23C;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.order-list {
  padding: 20rpx;
}

.order-card {
  background-color: #ffffff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.order-header {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.order-no {
  font-size: 26rpx;
  color: #999999;
}

.order-status {
  font-size: 26rpx;
  font-weight: bold;
}

.status-0 {
  color: #909399;
}

.status-1 {
  color: #E6A23C;
}

.status-2 {
  color: #67C23A;
}

.status-3 {
  color: #F56C6C;
}

.order-products {
  padding: 20rpx 30rpx;
}

.product-item {
  display: flex;
  padding: 12rpx 0;
}

.product-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  background-color: #F5F5F5;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 26rpx;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 26rpx;
  color: #E6A23C;
}

.product-qty {
  font-size: 24rpx;
  color: #999999;
}

.order-footer {
  padding: 16rpx 30rpx;
  border-top: 1rpx solid #F5F5F5;
}

.order-time {
  display: flex;
  margin-bottom: 8rpx;
}

.time-label {
  font-size: 24rpx;
  color: #999999;
}

.time-value {
  font-size: 24rpx;
  color: #E6A23C;
}

.order-amount {
  display: flex;
  justify-content: flex-end;
}

.amount-label {
  font-size: 26rpx;
  color: #666666;
}

.amount-value {
  font-size: 30rpx;
  color: #E6A23C;
  font-weight: bold;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  padding: 16rpx 30rpx;
  border-top: 1rpx solid #F5F5F5;
}

.btn-action {
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  margin-left: 16rpx;
}

.btn-cancel {
  border: 1rpx solid #F56C6C;
  color: #F56C6C;
}

.btn-confirm {
  background-color: #E6A23C;
  color: #ffffff;
}

.btn-reorder {
  border: 1rpx solid #E6A23C;
  color: #E6A23C;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 30rpx;
}

.go-shopping {
  padding: 20rpx 60rpx;
  background-color: #E6A23C;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.loading-tip {
  text-align: center;
  padding: 40rpx;
  font-size: 28rpx;
  color: #999999;
}
