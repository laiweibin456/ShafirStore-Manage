<view class="order-detail-page">
  <view class="status-bar" style="background-color: {{statusColor}}">
    <text class="status-text">{{statusText}}</text>
  </view>

  <view class="section">
    <view class="section-title">预约信息</view>
    <view class="info-row">
      <text class="info-label">订单编号</text>
      <text class="info-value">{{order.orderNo || order.id}}</text>
    </view>
    <view class="info-row" wx:if="{{order.pickupTime}}">
      <text class="info-label">取货时间</text>
      <text class="info-value highlight">{{order.pickupTime}}</text>
    </view>
    <view class="info-row" wx:if="{{order.remark}}">
      <text class="info-label">备注</text>
      <text class="info-value">{{order.remark}}</text>
    </view>
    <view class="info-row" wx:if="{{order.createTime}}">
      <text class="info-label">下单时间</text>
      <text class="info-value">{{order.createTime}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">预定商品</view>
    <view class="product-item" wx:for="{{order.items}}" wx:key="id">
      <image class="product-image" src="{{item.imageUrl || '/images/placeholder.jpg'}}" mode="aspectFill" />
      <view class="product-info">
        <text class="product-name">{{item.productName || item.name}}</text>
        <view wx:if="{{item.isPointsExchange}}" class="points-exchange-tag">
          <text>积分兑换</text>
        </view>
        <view class="product-bottom">
          <text class="product-price {{item.isPointsExchange ? 'points-price' : ''}}">¥{{item.price !== undefined ? item.price : item.productPrice}}</text>
          <text wx:if="{{item.isPointsExchange && item.requiredPoints}}" class="points-cost">({{item.requiredPoints}}积分)</text>
          <text wx:if="{{item.originalPrice}}" class="original-price">原价: ¥{{item.originalPrice}}</text>
          <text class="product-qty">x{{item.quantity}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="price-row">
      <text class="price-label">商品金额</text>
      <text class="price-value">¥{{order.totalAmount || '0.00'}}</text>
    </view>
    <view class="price-row" wx:if="{{order.discountAmount && order.discountAmount > 0}}">
      <text class="price-label">会员折扣</text>
      <text class="price-value discount">-¥{{order.discountAmount}}</text>
    </view>
    <view class="price-row" wx:if="{{order.pointsDeduct && order.pointsDeduct > 0}}">
      <text class="price-label">积分消耗</text>
      <text class="price-value points">-{{order.pointsDeduct}} 积分</text>
    </view>
    <view class="price-row total">
      <text class="price-label">实付金额</text>
      <text class="price-value total-price">¥{{order.payAmount || order.totalAmount || '0.00'}}</text>
    </view>
  </view>

  <view class="action-bar" wx:if="{{order.status === 1}}">
    <view class="btn-cancel" bindtap="cancelOrder">取消预约</view>
  </view>

  <view class="action-bar" wx:if="{{order.status === 3}}">
    <view class="btn-reorder" bindtap="goToProductList">再次预定</view>
  </view>
</view>
