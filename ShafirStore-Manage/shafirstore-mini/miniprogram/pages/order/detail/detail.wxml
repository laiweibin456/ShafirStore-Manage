<!--pages/order/detail/detail.wxml-->
<view class="order-detail-page">
  <!-- 订单状态 -->
  <view class="status-section status-{{order.status}}">
    <text class="status-text">{{statusText}}</text>
  </view>

  <!-- 订单信息 -->
  <view class="section">
    <view class="info-row">
      <text class="info-label">订单编号</text>
      <text class="info-value">{{order.orderNo}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">下单时间</text>
      <text class="info-value">{{order.createTime}}</text>
    </view>
  </view>

  <!-- 商品清单 -->
  <view class="section">
    <view class="section-title">商品清单</view>
    <view class="goods-list">
      <view class="goods-item" wx:for="{{order.items}}" wx:key="id">
        <image class="goods-image" src="{{item.imageUrl}}" mode="aspectFill" />
        <view class="goods-info">
          <text class="goods-name">{{item.productName}}</text>
          <text class="goods-price">¥{{item.price}}</text>
        </view>
        <text class="goods-qty">x{{item.quantity}}</text>
      </view>
    </view>
  </view>

  <!-- 价格信息 -->
  <view class="section">
    <view class="price-row">
      <text class="price-label">商品金额</text>
      <text class="price-value">¥{{order.totalAmount}}</text>
    </view>
    <view class="price-row" wx:if="{{order.discountAmount > 0}}">
      <text class="price-label">优惠</text>
      <text class="price-value">-¥{{order.discountAmount}}</text>
    </view>
    <view class="price-row total">
      <text class="price-label">实付金额</text>
      <text class="price-value">¥{{order.payAmount}}</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar" wx:if="{{order.status === 1}}">
    <view class="action-btn cancel" bindtap="cancelOrder">取消订单</view>
  </view>
</view>
