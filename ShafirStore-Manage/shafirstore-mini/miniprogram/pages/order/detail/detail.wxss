.order-detail-page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 120rpx;
}

.status-bar {
  padding: 40rpx 30rpx;
  color: #ffffff;
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
}

.section {
  background-color: #ffffff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #999999;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  text-align: right;
  margin-left: 20rpx;
}

.info-value.highlight {
  color: #E6A23C;
  font-weight: bold;
}

.product-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.product-item:last-child {
  border-bottom: none;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: #F5F5F5;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 28rpx;
  color: #333333;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 28rpx;
  color: #E6A23C;
  font-weight: bold;
}

.product-price.points-price {
  color: #67C23A;
}

.points-exchange-tag {
  display: inline-block;
  background-color: #FFF7E6;
  border: 1rpx solid #E6A23C;
  border-radius: 4rpx;
  padding: 4rpx 12rpx;
  margin-top: 8rpx;
}

.points-exchange-tag text {
  font-size: 22rpx;
  color: #E6A23C;
}

.points-cost {
  font-size: 22rpx;
  color: #E6A23C;
  margin-left: 8rpx;
}

.original-price {
  font-size: 22rpx;
  color: #999999;
  text-decoration: line-through;
  margin-left: 8rpx;
}

.price-value.points {
  color: #E6A23C;
}

.product-qty {
  font-size: 26rpx;
  color: #999999;
}

.price-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.price-row.total {
  border-top: 1rpx solid #EEEEEE;
  margin-top: 12rpx;
  padding-top: 20rpx;
}

.price-label {
  font-size: 28rpx;
  color: #666666;
}

.price-value {
  font-size: 28rpx;
  color: #333333;
}

.price-value.discount {
  color: #67C23A;
}

.total-price {
  font-size: 36rpx;
  color: #E6A23C;
  font-weight: bold;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background-color: #ffffff;
  display: flex;
  justify-content: center;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.btn-cancel {
  padding: 20rpx 80rpx;
  border: 2rpx solid #F56C6C;
  color: #F56C6C;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.btn-cancel:active {
  background-color: #FEF0F0;
}

.btn-reorder {
  padding: 20rpx 80rpx;
  background-color: #E6A23C;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.btn-reorder:active {
  opacity: 0.85;
}
