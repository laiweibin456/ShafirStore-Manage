/* pages/index/index.wxss - 首页样式 (极简设计) */

/* ==================== 页面基础布局 ==================== */
.index-page {
  min-height: 100vh;
  background-color: #F5F5F5;
  display: flex;
  flex-direction: column;
}

/* ==================== 上部60%品牌宣传区域 ==================== */
.brand-section {
  position: relative;
  width: 100%;
  height: 60vh;
  min-height: 500rpx;
  overflow: hidden;
}

.brand-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.brand-image {
  width: 100%;
}

.gradient-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40%;
  background: linear-gradient(
    to top,
    rgba(245, 245, 245, 1) 0%,
    rgba(245, 245, 245, 0.8) 40%,
    transparent 100%
  );
}

.status-bar-placeholder {
  height: calc(env(safe-area-inset-top) + 44rpx);
}

/* ==================== 下部UI区域 ==================== */
.bottom-section {
  flex: 1;
  margin-top: -80rpx;
  padding: 0 24rpx;
  padding-bottom: env(safe-area-inset-bottom);
  position: relative;
  z-index: 10;
}

/* ==================== 用户信息卡片 ==================== */
.user-card {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.user-card:active {
  opacity: 0.9;
}

.user-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  background-color: #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.user-avatar text {
  font-size: 28rpx;
  color: #999999;
  font-weight: 500;
}

.user-greeting {
  flex: 1;
  min-width: 0;
}

.greeting-text {
  display: block;
  font-size: 30rpx;
  color: #333333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.member-tag {
  display: inline-block;
  border: 1rpx solid #D0D0D0;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
}

.tag-text {
  font-size: 20rpx;
  color: #999999;
}

.user-stats {
  display: flex;
  align-items: center;
  gap: 28rpx;
  flex-shrink: 0;
}

.stat-item {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 32rpx;
  color: #333333;
  font-weight: bold;
  line-height: 1.2;
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: #999999;
  margin-top: 4rpx;
}

/* ==================== 双大按钮区域 ==================== */
.action-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 36rpx 24rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.15s ease;
}

.action-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 按钮图标圆圈 */
.btn-icon-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid #D0D0D0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

/* CSS纯线条图标 - 购物袋 */
.icon-bag {
  width: 28rpx;
  height: 24rpx;
  border: 3rpx solid #333333;
  border-radius: 2rpx;
  position: relative;
  margin-top: 8rpx;
}

.icon-bag::before {
  content: '';
  position: absolute;
  top: -12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 16rpx;
  height: 12rpx;
  border: 3rpx solid #333333;
  border-bottom: none;
  border-radius: 8rpx 8rpx 0 0;
}

/* CSS纯线条图标 - 外卖配送 */
.icon-delivery {
  width: 28rpx;
  height: 3rpx;
  background-color: #333333;
  position: relative;
}

.icon-delivery::before {
  content: '';
  position: absolute;
  right: -2rpx;
  top: -7rpx;
  width: 0;
  height: 0;
  border-left: 12rpx solid #333333;
  border-top: 8rpx solid transparent;
  border-bottom: 8rpx solid transparent;
}

/* CSS纯线条图标 - 星形(积分) */
.icon-star {
  width: 20rpx;
  height: 20rpx;
  position: relative;
}

.icon-star::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-bottom: 14rpx solid #333333;
}

.icon-star::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 14rpx solid #333333;
}

.btn-title {
  display: block;
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 6rpx;
  letter-spacing: 1rpx;
}

.btn-desc {
  display: block;
  font-size: 22rpx;
  color: #999999;
}

/* ==================== 功能入口区域 ==================== */
.function-entries {
  margin-bottom: 20rpx;
}

.entry-item {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.15s ease;
}

.entry-item:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.entry-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid #D0D0D0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

/* CSS纯线条图标 - 店铺 */
.icon-store {
  width: 24rpx;
  height: 20rpx;
  border: 3rpx solid #333333;
  border-radius: 2rpx 2rpx 0 0;
  position: relative;
}

.icon-store::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: -4rpx;
  right: -4rpx;
  height: 10rpx;
  background-color: #333333;
  clip-path: polygon(0 100%, 50% 0, 100% 100%);
}

.icon-store::after {
  content: '';
  position: absolute;
  bottom: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 6rpx;
  border: 2rpx solid #333333;
  border-top: none;
}

.entry-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

/* ==================== 底部安全区域 ==================== */
.safe-area-bottom {
  height: 40rpx;
}

/* ==================== 响应式适配 ==================== */
@media screen and (max-width: 320px) {
  .btn-title {
    font-size: 28rpx;
  }

  .stat-value {
    font-size: 28rpx;
  }

  .user-stats {
    gap: 20rpx;
  }
}

@media screen and (min-width: 414px) {
  .brand-section {
    min-height: 560rpx;
  }

  .action-btn {
    padding: 44rpx 28rpx 36rpx;
  }
}
