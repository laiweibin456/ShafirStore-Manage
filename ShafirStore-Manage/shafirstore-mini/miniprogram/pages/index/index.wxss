/* pages/index/index.wxss - 首页样式 */

.index-page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 20rpx;
}

/* 搜索栏 */
.search-bar {
  background-color: #ffffff;
  padding: 20rpx 30rpx;
}

.search-text {
  display: block;
  background-color: #F5F5F5;
  border-radius: 30rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  color: #999999;
  text-align: center;
}

/* 轮播图 */
.banner-swiper {
  height: 300rpx;
  margin: 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 分类入口 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  background-color: #ffffff;
  padding: 30rpx 20rpx;
  margin: 0 20rpx;
  border-radius: 12rpx;
}

.category-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #F5F5F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 26rpx;
  color: #333333;
}

/* 区块 */
.section {
  background-color: #ffffff;
  margin: 20rpx;
  padding: 20rpx;
  border-radius: 12rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.section-more {
  font-size: 26rpx;
  color: #999999;
}

/* 商品横向滚动 */
.product-scroll {
  white-space: nowrap;
  height: 320rpx;
}

.product-list {
  display: inline-flex;
}

.product-card {
  width: 240rpx;
  margin-right: 20rpx;
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
}

.product-image {
  width: 240rpx;
  height: 240rpx;
}

.product-info {
  padding: 16rpx;
}

.product-name {
  display: block;
  font-size: 28rpx;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-price {
  display: block;
  font-size: 32rpx;
  color: #E6A23C;
  font-weight: bold;
  margin-top: 10rpx;
}

/* 商品网格 */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-grid .product-card {
  width: 48%;
  margin-bottom: 20rpx;
}

.product-grid .product-image {
  width: 100%;
  height: 320rpx;
}

.product-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 8rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.product-add {
  width: 48rpx;
  height: 48rpx;
  background-color: #E6A23C;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}
