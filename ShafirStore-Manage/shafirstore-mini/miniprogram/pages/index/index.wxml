<!--pages/index/index.wxml - 首页 (品牌宣传+用户信息+功能入口)-->
<view class="index-page">
  <!-- 上部60%品牌宣传图片区域 -->
  <view class="brand-section">
    <view class="brand-bg">
      <image
        class="brand-image"
        src="/images/brand-poster.jpg"
        mode="aspectFill"
      ></image>
    </view>
    <view class="gradient-overlay"></view>
    <view class="status-bar-placeholder"></view>
  </view>

  <!-- 下部UI区域 -->
  <view class="bottom-section">
    <!-- 用户信息卡片 -->
    <view class="user-card" bindtap="goToMember">
      <view class="user-left">
        <view class="user-avatar">
          <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
          <text wx:else>LE</text>
        </view>
        <view class="user-greeting">
          <text class="greeting-text">Hi {{userInfo.nickName || '你好'}}</text>
          <view class="member-tag">
            <text class="tag-text">{{memberInfo.levelName || '普通会员'}}</text>
          </view>
        </view>
      </view>
      <view class="user-stats">
        <view class="stat-item">
          <text class="stat-value">{{memberInfo.balance || 0}}</text>
          <text class="stat-label">余额</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{memberInfo.points || 0}}</text>
          <text class="stat-label">积分</text>
        </view>
        <view class="stat-item">
          <text class="stat-value">{{memberInfo.coupons || 1}}</text>
          <text class="stat-label">优惠券</text>
        </view>
      </view>
    </view>

    <!-- 双大按钮区域 -->
    <view class="action-buttons">
      <view class="action-btn" bindtap="goToPickup">
        <view class="btn-icon-circle">
          <view class="icon-bag"></view>
        </view>
        <text class="btn-title">到店自提</text>
        <text class="btn-desc">当天到店取餐</text>
      </view>
      <view class="action-btn" bindtap="goToTakeaway">
        <view class="btn-icon-circle">
          <view class="icon-delivery"></view>
        </view>
        <text class="btn-title">自营外卖</text>
        <text class="btn-desc">满50元起送</text>
      </view>
    </view>

    <!-- 功能入口区域 -->
    <view class="function-entries">
      <view class="entry-item" bindtap="goToPoints">
        <view class="entry-icon">
          <view class="icon-star"></view>
        </view>
        <text class="entry-title">积分兑换</text>
      </view>
      <view class="entry-item" bindtap="goToAddress">
        <view class="entry-icon">
          <view class="icon-pin"></view>
        </view>
        <text class="entry-title">门店地址</text>
      </view>
      <view class="entry-item" bindtap="goToStoreSelect">
        <view class="entry-icon">
          <view class="icon-store"></view>
        </view>
        <text class="entry-title">{{currentStoreName || '选择门店'}}</text>
      </view>
    </view>

    <!-- 底部安全区域 -->
    <view class="safe-area-bottom"></view>
  </view>
</view>
