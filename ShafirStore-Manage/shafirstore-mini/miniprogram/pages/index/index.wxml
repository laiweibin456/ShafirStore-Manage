<!--pages/index/index.wxml-->
<view class="index-page">
  <!-- 搜索栏 -->
  <view class="search-bar" bindtap="goToSearch">
    <text class="search-text">搜索商品名称...</text>
  </view>

  <!-- 轮播图 -->
  <swiper class="banner-swiper" indicator-dots autoplay circular>
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <image class="banner-image" src="{{item.image}}" mode="aspectFill" />
    </swiper-item>
  </swiper>

  <!-- 分类入口 -->
  <view class="category-grid">
    <view class="category-item" wx:for="{{categories}}" wx:key="id" bindtap="goToCategory" data-id="{{item.id}}">
      <image class="category-icon" src="{{item.icon}}" mode="aspectFit" />
      <text class="category-name">{{item.name}}</text>
    </view>
  </view>

  <!-- 热销榜单 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">热销榜单</text>
      <text class="section-more" bindtap="goToList" data-type="hot">查看全部 ></text>
    </view>
    <scroll-view class="product-scroll" scroll-x>
      <view class="product-list">
        <view class="product-card" wx:for="{{hotProducts}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
          <image class="product-image" src="{{item.imageUrl}}" mode="aspectFill" />
          <view class="product-info">
            <text class="product-name">{{item.name}}</text>
            <text class="product-price">¥{{item.price}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 新品上架 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">新品上架</text>
      <text class="section-more" bindtap="goToList" data-type="new">查看全部 ></text>
    </view>
    <view class="product-grid">
      <view class="product-card" wx:for="{{newProducts}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <image class="product-image" src="{{item.imageUrl}}" mode="aspectFill" />
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <text class="product-price">¥{{item.price}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
