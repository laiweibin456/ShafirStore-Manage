<view class="product-list-page">
  <view class="main-content">
    <scroll-view class="category-sidebar" scroll-y>
      <view class="category-item {{currentCategoryIndex === index ? 'active' : ''}}"
            wx:for="{{categories}}" wx:key="id"
            bindtap="switchCategory" data-index="{{index}}">
        <text class="category-name">{{item.name}}</text>
        <view class="category-indicator" wx:if="{{currentCategoryIndex === index}}"></view>
      </view>
    </scroll-view>

    <scroll-view class="product-content" scroll-y>
      <view class="product-list">
        <view class="product-item" wx:for="{{products}}" wx:key="id">
          <image class="product-image" src="{{item.imageUrl || '/images/placeholder.jpg'}}" mode="aspectFill" bindtap="goToDetail" data-id="{{item.id}}" />
          <view class="product-info">
            <text class="product-name" bindtap="goToDetail" data-id="{{item.id}}">{{item.name}}</text>
            <text class="product-desc" wx:if="{{item.description}}">{{item.description}}</text>
            <view class="product-bottom">
              <text class="product-price">¥{{item.price}}</text>
              <view class="add-cart-btn" catchtap="addToCart" data-item="{{item}}">+</view>
            </view>
          </view>
        </view>
      </view>

      <view class="loading-tip" wx:if="{{loading}}">加载中...</view>
      <view class="empty-tip" wx:if="{{!loading && products.length === 0}}">
        <text class="empty-text">该分类暂无商品</text>
      </view>
    </scroll-view>
  </view>

  <view class="cart-bar">
    <view class="cart-info" bindtap="goToCart">
      <view class="cart-icon-wrap">
        <text class="cart-icon">🛒</text>
        <view class="cart-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
      </view>
      <view class="cart-total">
        <text class="total-label">合计：</text>
        <text class="total-price" wx:if="{{cartCount > 0}}">查看购物车</text>
        <text class="total-price" wx:else>空</text>
      </view>
    </view>
    <view class="cart-go-btn" bindtap="goToCart">去结算</view>
  </view>
</view>
