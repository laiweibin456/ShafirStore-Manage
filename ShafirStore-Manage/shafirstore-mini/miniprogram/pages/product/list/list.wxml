<!--pages/product/list/list.wxml-->
<view class="product-list-page">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索商品名称..." bindinput="onSearch" value="{{keyword}}" />
  </view>

  <!-- 分类筛选 -->
  <scroll-view class="category-scroll" scroll-x>
    <view class="category-list">
      <view class="category-item {{categoryId === null ? 'active' : ''}}" bindtap="selectCategory" data-id="">全部</view>
      <view
        class="category-item {{categoryId === item.id ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="id"
        bindtap="selectCategory"
        data-id="{{item.id}}"
      >
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <!-- 商品列表 -->
  <scroll-view class="product-scroll" scroll-y bindscrolltolower="loadMore">
    <view class="product-grid">
      <view class="product-card" wx:for="{{products}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <image class="product-image" src="{{item.imageUrl}}" mode="aspectFill" />
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <text class="product-desc">{{item.description}}</text>
          <view class="product-bottom">
            <text class="product-price">¥{{item.price}}</text>
            <view class="product-add" catchtap="addToCart" data-id="{{item.id}}">+</view>
          </view>
        </view>
      </view>
    </view>

    <view class="loading-more" wx:if="{{hasMore}}">
      <text>加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && products.length > 0}}">
      <text>没有更多了</text>
    </view>
    <view class="empty" wx:if="{{products.length === 0 && !loading}}">
      <text>暂无商品</text>
    </view>
  </scroll-view>
</view>
