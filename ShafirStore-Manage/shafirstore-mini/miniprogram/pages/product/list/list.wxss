.product-list-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F5F5F5;
}

.main-content {
  flex: 1;
  display: flex;
  overflow: hidden;
}

.category-sidebar {
  width: 180rpx;
  height: 100%;
  background-color: #F7F7F7;
  flex-shrink: 0;
}

.category-item {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.category-item.active {
  background-color: #FFFFFF;
}

.category-item.active .category-name {
  color: #333333;
  font-weight: bold;
}

.category-indicator {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 36rpx;
  background-color: #E6A23C;
  border-radius: 0 3rpx 3rpx 0;
}

.category-name {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.3;
  text-align: center;
  padding: 0 12rpx;
}

.product-content {
  flex: 1;
  height: 100%;
  background-color: #FFFFFF;
}

.product-list {
  padding: 20rpx 24rpx;
}

.product-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.product-item:last-child {
  border-bottom: none;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background-color: #F5F5F5;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  margin-left: 20rpx;
  min-width: 0;
}

.product-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-desc {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.product-price {
  font-size: 32rpx;
  color: #E6A23C;
  font-weight: bold;
}

.add-cart-btn {
  width: 44rpx;
  height: 44rpx;
  background-color: #E6A23C;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 1;
}

.add-cart-btn:active {
  opacity: 0.85;
}

.loading-tip {
  text-align: center;
  padding: 40rpx;
  font-size: 28rpx;
  color: #999999;
}

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.cart-bar {
  display: flex;
  align-items: center;
  height: 100rpx;
  background-color: #333333;
  padding: 0 24rpx;
  flex-shrink: 0;
}

.cart-info {
  flex: 1;
  display: flex;
  align-items: center;
}

.cart-icon-wrap {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  background-color: #4A4A4A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: -30rpx;
  border: 6rpx solid #333333;
}

.cart-icon {
  font-size: 40rpx;
}

.cart-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 32rpx;
  height: 32rpx;
  background-color: #FF4D4F;
  color: #FFFFFF;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

.cart-total {
  margin-left: 20rpx;
}

.total-label {
  font-size: 24rpx;
  color: #999999;
}

.total-price {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: bold;
}

.cart-go-btn {
  padding: 16rpx 40rpx;
  background-color: #E6A23C;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.cart-go-btn:active {
  opacity: 0.85;
}
