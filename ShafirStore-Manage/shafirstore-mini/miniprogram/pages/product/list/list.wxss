/* pages/product/list/list.wxss - 商品列表页样式 */

.product-list-page {
  min-height: 100vh;
  background-color: #F5F5F5;
}

/* 搜索栏 */
.search-bar {
  background-color: #ffffff;
  padding: 20rpx 30rpx;
}

.search-input {
  background-color: #F5F5F5;
  border-radius: 30rpx;
  padding: 16rpx 30rpx;
  font-size: 28rpx;
}

/* 分类筛选 */
.category-scroll {
  background-color: #ffffff;
  white-space: nowrap;
  padding: 20rpx 0;
}

.category-list {
  display: inline-flex;
  padding: 0 20rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 30rpx;
  margin: 0 10rpx;
  background-color: #F5F5F5;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #333333;
}

.category-item.active {
  background-color: #E6A23C;
  color: #ffffff;
}

/* 商品列表 */
.product-scroll {
  height: calc(100vh - 200rpx);
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 20rpx;
}

.product-card {
  width: 48%;
  background-color: #ffffff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.product-image {
  width: 100%;
  height: 320rpx;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  display: block;
  font-size: 28rpx;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 8rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.product-price {
  font-size: 32rpx;
  color: #E6A23C;
  font-weight: bold;
}

.product-add {
  width: 48rpx;
  height: 48rpx;
  background-color: #E6A23C;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

/* 加载状态 */
.loading-more, .no-more, .empty {
  text-align: center;
  padding: 40rpx;
  color: #999999;
  font-size: 28rpx;
}
