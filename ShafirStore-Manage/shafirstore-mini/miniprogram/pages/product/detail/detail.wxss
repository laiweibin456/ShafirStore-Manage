.product-detail-page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 120rpx;
}

.image-swiper {
  height: 750rpx;
  background-color: #ffffff;
}

.single-image {
  height: 750rpx;
  background-color: #ffffff;
}

.product-image {
  width: 100%;
  height: 100%;
}

.price-section {
  background-color: #ffffff;
  padding: 30rpx;
  display: flex;
  align-items: baseline;
}

.price {
  font-size: 48rpx;
  color: #E6A23C;
  font-weight: bold;
}

.unit {
  font-size: 28rpx;
  color: #999999;
  margin-left: 10rpx;
}

.info-section {
  background-color: #ffffff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999999;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
}

.detail-section {
  background-color: #ffffff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
}

.detail-content {
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #ffffff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.action-icons {
  display: flex;
}

.icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
  position: relative;
}

.iconfont {
  font-size: 40rpx;
}

.icon-text {
  font-size: 22rpx;
  color: #666666;
  margin-top: 4rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  min-width: 32rpx;
  height: 32rpx;
  background-color: #FF4D4F;
  color: #FFFFFF;
  font-size: 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

.action-buttons {
  display: flex;
}

.btn-add-cart, .btn-buy {
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  margin-left: 20rpx;
}

.btn-add-cart {
  background-color: #FF9800;
  color: #ffffff;
}

.btn-buy {
  background-color: #E6A23C;
  color: #ffffff;
}
