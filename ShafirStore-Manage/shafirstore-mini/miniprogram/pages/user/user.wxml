<!--pages/user/user.wxml-->
<view class="user-page">
  <!-- 用户信息 -->
  <view class="user-info" wx:if="{{hasUserInfo}}">
    <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
    <view class="info-text">
      <text class="nickname">{{userInfo.nickName}}</text>
      <text class="phone">{{userInfo.phone}}</text>
    </view>
  </view>
  <view class="user-info" wx:else>
    <button class="login-btn" bindtap="login">登录</button>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goToOrders">
      <text class="menu-icon">📋</text>
      <text class="menu-text">我的订单</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="clearCache">
      <text class="menu-icon">🗑️</text>
      <text class="menu-text">清除缓存</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="aboutUs">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="logout-btn" wx:if="{{hasUserInfo}}" bindtap="logout">
    退出登录
  </view>
</view>
