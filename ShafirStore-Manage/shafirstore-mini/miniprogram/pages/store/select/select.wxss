.store-select-page {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.loading-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

.store-tip {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.store-list {
  padding-bottom: 40rpx;
}

.store-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #eee;
  transition: all 0.2s;
}

.store-item-active {
  border-color: #E6A23C;
  background: #fffbf0;
}

.store-info {
  flex: 1;
}

.store-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.store-badge {
  font-size: 20rpx;
  color: #fff;
  background: #E6A23C;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-weight: normal;
}

.store-address {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.store-meta {
  display: flex;
  gap: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.store-check {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  font-size: 40rpx;
  color: #E6A23C;
  font-weight: bold;
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 100rpx 0;
}
